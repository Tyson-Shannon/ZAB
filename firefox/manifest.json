{
  "manifest_version": 3,
  "name": "ZAB",
  "version": "1.0",
  "description": "Automatically forces Google searches into Web mode that has no AI overview. https://github.com/Tyson-Shannon/ZAB",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "*://www.google.com/*",
    "*://www.google.com/search*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZAB"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "google-web-only@tysons.tech",
      "data_collection_permissions": {
      "required": ["none"]
      }
    }
  }
}